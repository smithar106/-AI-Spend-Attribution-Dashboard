# Standard Anthropic API key (a REGULAR key from console.anthropic.com -- NOT an admin key).
# Used only for live Claude inference elsewhere in the app. The Spend Attribution
# dashboard runs on built-in demo data and makes no admin / usage-reporting calls.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: size of the demo lookback window in days (defaults to 30).
LOOKBACK_DAYS=30
