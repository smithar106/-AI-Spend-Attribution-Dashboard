# Anthropic Admin (org-level) API key. Must be an ADMIN key (starts with sk-ant-admin...)
# Create one at: https://console.anthropic.com/settings/admin-keys
ANTHROPIC_API_KEY=sk-ant-admin-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Admin (org-level) API key. Must be an ADMIN key (starts with sk-admin-...)
# Create one at: https://platform.openai.com/settings/organization/admin-keys
OPENAI_API_KEY=sk-admin-xxxxxxxxxxxxxxxxxxxxxxxx

# Organization IDs (used for scoping / request headers)
ANTHROPIC_ORG_ID=
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxx

# Optional: number of days to look back (defaults to 30)
LOOKBACK_DAYS=30
